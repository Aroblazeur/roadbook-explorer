# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# audit / test scripts (may contain secrets)
/scripts/audit-*
/scripts/test-pup*

# logs
dev-server.log
/dev-server.log

# validation files
/validation/

# real GPX migration plan (contains actual data)
/reports/gpx-migration-plan.json
/reports/gpx-migration-rollback.json
/reports/gpx-migration-application-result.json


# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
